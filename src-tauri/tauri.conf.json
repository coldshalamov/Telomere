{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Telomere",
  "version": "0.1.0",
  "identifier": "com.telomere.console",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Telomere — Operator Console",
        "width": 1500,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
